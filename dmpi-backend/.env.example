# Copier ce fichier vers .env puis adapter les valeurs (.env n'est jamais committé).

# ─── PostgreSQL ────────────────────────────────────────────────────────────
# Valeurs pour les outils lancés depuis l'hôte (pgAdmin, scripts hors Docker).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=dmpi_db

# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://*:*@localhost:27017/dmpi_db?authSource=admin
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Sécurité ───────────────────────────────────────────────────────────────
# Générer une clé : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_moi_avec_une_cle_aleatoire_longue
ADMIN_INITIAL_PASSWORD=change_moi
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ─── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
